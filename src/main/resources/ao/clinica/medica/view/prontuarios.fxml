<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20.0" style="-fx-padding: 32;" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ao.clinica.medica.controller.ProntuarioController">
    <children>
        <HBox alignment="CENTER_LEFT" spacing="20.0">
            <children>
                <VBox HBox.hgrow="ALWAYS">
                    <children>
                        <Label text="Prontuário Eletrónico" styleClass="heading-1" />
                        <Label text="Registo de diagnósticos, prescrições e evolução clínica do paciente." style="-fx-text-fill: #64748B; -fx-font-size: 14px;" />
                    </children>
                </VBox>
            </children>
        </HBox>

        <HBox spacing="24.0" VBox.vgrow="ALWAYS">
            <children>
                <VBox prefWidth="320.0" spacing="15.0">
                    <children>
                        <Label text="ATENDIMENTOS PENDENTES" style="-fx-font-size: 11px; -fx-text-fill: #0EA5E9; -fx-font-weight: bold;" />
                        <ListView fx:id="listConsultasAtivas" VBox.vgrow="ALWAYS" style="-fx-background-radius: 8; -fx-border-radius: 8;" />
                        <Button fx:id="btnIniciarAtendimento" maxWidth="Infinity" text="Abrir Ficha Clínica" styleClass="btn-primary" onAction="#handleAbrirFicha" />
                    </children>
                </VBox>

                <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="20.0">
                    <children>
                        <HBox spacing="15.0" alignment="CENTER_LEFT">
                            <children>
                                <Label fx:id="lblPacienteSelecionado" text="Selecione um paciente para iniciar" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0F172A;" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label fx:id="lblDataHoje" text="Data: 17/06/2026" style="-fx-text-fill: #64748B;" />
                            </children>
                        </HBox>

                        <Separator style="-fx-opacity: 0.1;" />

                        <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                            <children>
                                <Label text="Diagnóstico Clínico" styleClass="label-custom" />
                                <TextArea fx:id="txtDiagnostico" prefHeight="120.0" wrapText="true" promptText="Descreva a hipótese diagnóstica e sintomas observados..." styleClass="text-field-custom" />

                                <Label text="Prescrição Médica (Receituário)" styleClass="label-custom" />
                                <TextArea fx:id="txtPrescricao" prefHeight="120.0" wrapText="true" promptText="Indique a medicação, dosagem e posologia..." styleClass="text-field-custom" />

                                <Label text="Observações Adicionais" styleClass="label-custom" />
                                <TextArea fx:id="txtObservacoes" prefHeight="80.0" wrapText="true" promptText="Notas internas ou recomendações de retorno..." styleClass="text-field-custom" />
                            </children>
                        </VBox>

                        <HBox spacing="15.0" alignment="CENTER_RIGHT">
                            <children>
                                <Button text="Visualizar Histórico Anterior" style="-fx-background-color: #F1F5F9; -fx-text-fill: #0F172A; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 6;" />
                                <Button fx:id="btnFinalizar" onAction="#handleFinalizarAtendimento" text="Finalizar e Guardar Prontuário" style="-fx-background-color: #10B981; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 25; -fx-background-radius: 6;" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</VBox>